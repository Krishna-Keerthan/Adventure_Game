# App
API_PREFIX=/api
DEBUG=False

# Database
DATABASE_URL=sqlite:///./adventure_game.db
# DATABASE_URL=postgresql://user:password@host:5432/adventure_game

# Security
SECRET_KEY=your-very-long-random-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Groq
GROQ_API_KEY=your-groq-api-key

# Redis — get this from upstash.com (free)
# Leave empty to disable caching (app still works without it)
UPSTASH_REDIS_URL=rediss://default:xxxxx@xxx-xxx.upstash.io:6379